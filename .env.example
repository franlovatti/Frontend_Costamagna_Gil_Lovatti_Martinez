# ===========================
# GOOGLE MAPS API
# ===========================
# Obtén tu API key en: https://console.cloud.google.com/
# IMPORTANTE: Debe comenzar con "AIza"
# Esta es una key de EJEMPLO - Genera la tuya propia
VITE_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# ===========================
# BACKEND API (Opcional)
# ===========================
# Por defecto usa http://localhost:3000
# Solo necesitas configurar esto si tu backend usa otro puerto
# VITE_API_URL=http://localhost:3000

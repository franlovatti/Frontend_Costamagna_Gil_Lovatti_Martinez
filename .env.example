# ===========================
# GOOGLE MAPS API
# ===========================
# Obtén tu API key en: https://console.cloud.google.com/
# IMPORTANTE: Debe comenzar con "AIza"
# Esta es una key de EJEMPLO - Genera la tuya propia
VITE_GOOGLE_MAPS_API_KEY=tu_google_maps_api_key_aqui

# ===========================
# BACKEND API
# ===========================
# URL del servidor backend (incluyendo protocolo pero SIN /api)
# Por defecto: http://localhost:3000
# Ejemplo producción: https://api.tudominio.com
VITE_API_URL=http://localhost:3000
